{
  "$schema": "../config/config.schema.json",
  "name": "Sample EnterpriseSecurityIQ Assessment",
  "frameworks": ["MCSB", "NIST-800-53"],
  "logLevel": "INFO",
  "outputFormats": ["json", "html", "md"],
  "outputDir": "./output",
  "checkpointEnabled": true,
  "additionalTenants": [],
  "auth": {
    "tenantId": "00000000-0000-0000-0000-000000000000",
