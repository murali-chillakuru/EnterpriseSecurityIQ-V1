# ── Azure OpenAI ────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-ai-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_FALLBACK_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Foundry (agent registration in ai.azure.com) ───────
FOUNDRY_PROJECT_ENDPOINT=https://<your-ai-resource>.services.ai.azure.com/api/projects/<project-name>

# ── Azure Tenant (for compliance scanning) ──────────────
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Managed Identity (set automatically on Container App)
# AZURE_CLIENT_ID=

# ── Report Storage (persistent across restarts) ────────
# REPORT_STORAGE_ACCOUNT=<your-storage-account>
# REPORT_STORAGE_CONTAINER=reports

# ── Optional: Service Principal auth ────────────────────
# AZURE_CLIENT_SECRET=

# ── Optional: Config file path ──────────────────────────
# ENTERPRISESECURITYIQ_CONFIG=./config/enterprisesecurityiq.config.json

# ── Optional: Override frameworks ───────────────────────
# ENTERPRISESECURITYIQ_FRAMEWORKS=FedRAMP,CIS,ISO-27001

# ── Optional: Log level ────────────────────────────────
# ENTERPRISESECURITYIQ_LOG_LEVEL=INFO
